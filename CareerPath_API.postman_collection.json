{
  "info": {
    "name": "Career Path API",
    "description": "Postman collection for the Flask Career Path Guidance API.\nHierarchy: Stream → Node (infinite tree). A node with no children is a leaf.\nBooks, institutes and job sectors can only be assigned to leaf nodes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "8a4d5ff7-5d6e-4ed6-9686-e1d4b9bdc6f2"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:5000"
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "streamId",
      "value": "1"
    },
    {
      "key": "nodeId",
      "value": "1",
      "description": "Use a root node ID (parent_id=null) to browse the tree top-down."
    },
    {
      "key": "leafNodeId",
      "value": "10",
      "description": "ID of a leaf node (no children) — required for /details and /assignments."
    },
    {
      "key": "bookId",
      "value": "1"
    },
    {
      "key": "instId",
      "value": "1"
    },
    {
      "key": "sectorId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Public",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "health"]
            },
            "description": "Returns {\"status\": \"ok\"} if the server is running."
          },
          "response": []
        },
        {
          "name": "Streams",
          "item": [
            {
              "name": "List Streams",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/streams",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "streams"]
                },
                "description": "Returns all streams. Each stream includes root_node_ids (top-level nodes with parent_id=null)."
              },
              "response": []
            },
            {
              "name": "Get Stream By ID",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/streams/{{streamId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "streams", "{{streamId}}"]
                },
                "description": "Returns a single stream with root_node_ids."
              },
              "response": []
            },
            {
              "name": "List Root Nodes By Stream",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/streams/{{streamId}}/nodes",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "streams", "{{streamId}}", "nodes"]
                },
                "description": "Returns root-level nodes (parent_id=null) for a stream. These are the top-level entry points for the infinite tree. Each node includes is_leaf and child_ids."
              },
              "response": []
            }
          ]
        },
        {
          "name": "Nodes",
          "item": [
            {
              "name": "Get Node By ID",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/nodes/{{nodeId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "nodes", "{{nodeId}}"]
                },
                "description": "Returns one node with stream_id, parent_id, is_leaf (computed) and child_ids."
              },
              "response": []
            },
            {
              "name": "List Children By Node",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/nodes/{{nodeId}}/children",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "nodes", "{{nodeId}}", "children"]
                },
                "description": "Returns direct child nodes. Each child includes is_leaf and child_ids for further traversal."
              },
              "response": []
            },
            {
              "name": "Get Node Details (leaf only)",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/nodes/{{leafNodeId}}/details",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "nodes", "{{leafNodeId}}", "details"]
                },
                "description": "Returns books, institutes, and job sectors linked to a node.\nReturns 400 if the node has children (non-leaf). Use a {{leafNodeId}} for this request."
              },
              "response": []
            }
          ]
        },
        {
          "name": "Resources",
          "item": [
            {
              "name": "List All Books",
              "request": {
                "method": "GET",

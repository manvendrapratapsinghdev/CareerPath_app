    {
      "name": "Admin",
      "item": [
        {
          "name": "Auth",
          "item": [
            {
              "name": "Login",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "var json = pm.response.json();",
                      "if (json.token) {",
                      "  pm.collectionVariables.set('adminToken', json.token);",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/admin/login",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "admin", "login"]
                },
                "description": "Authenticates and returns a JWT token. The test script auto-saves the token to {{adminToken}}."
              },
              "response": []
            },
            {
              "name": "Verify Token",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{adminToken}}" }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/admin/verify",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "admin", "verify"]
                },
                "description": "Returns {\"valid\": true} if the token is valid."
              },
              "response": []
            }
          ]
        },
        {
          "name": "Streams",
          "item": [
            {
              "name": "Create Stream",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{adminToken}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"slug\": \"new_stream\",\n  \"name\": \"New Stream\",\n  \"intro\": \"Optional intro text\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/admin/streams",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "admin", "streams"]
                },
                "description": "Creates a new stream. Required: slug, name."
              },
              "response": []
            },
            {
              "name": "Update Stream",
              "request": {
                "method": "PUT",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{adminToken}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Updated Stream Name\",\n  \"intro\": \"Updated intro\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/admin/streams/{{streamId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "admin", "streams", "{{streamId}}"]
                },
                "description": "Updates a stream by ID."
              },
              "response": []
            },
            {
              "name": "Delete Stream",
              "request": {
                "method": "DELETE",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{adminToken}}" }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/admin/streams/{{streamId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "admin", "streams", "{{streamId}}"]
                },
                "description": "Deletes a stream and all its nodes (cascade)."
              },
              "response": []
            }
          ]
        },
        {
          "name": "Nodes",
          "item": [
            {
              "name": "List All Nodes",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{adminToken}}" }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/admin/nodes",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "admin", "nodes"]
                },
                "description": "Returns flat list of all nodes with their stream names and computed is_leaf."
              },
              "response": []
            },
            {
              "name": "List Leaf Nodes",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{adminToken}}" }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/admin/nodes?is_leaf=true",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "admin", "nodes"],
                  "query": [
                    { "key": "is_leaf", "value": "true" }
                  ]
                },
                "description": "Returns only leaf nodes (nodes with no children)."
              },
              "response": []
            },
            {
              "name": "List Nodes By Stream",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{adminToken}}" }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/admin/nodes?stream_id={{streamId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "admin", "nodes"],
                  "query": [
                    { "key": "stream_id", "value": "{{streamId}}" }
                  ]
                },
                "description": "Returns all nodes belonging to a specific stream."
              },
              "response": []
            },
            {
              "name": "Create Node",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{adminToken}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"slug\": \"new_career\",\n  \"name\": \"New Career\",\n  \"stream_id\": 1,\n  \"parent_id\": null,\n  \"intro\": \"Optional intro\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/admin/nodes",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "admin", "nodes"]
                },
                "description": "Creates a new node. Required: slug, name, stream_id.\nSet parent_id=null to create a root node; set parent_id to an existing node ID to create a sub-node.\nis_leaf is computed automatically — do not pass it."
              },
              "response": []
            },
            {
              "name": "Update Node",
              "request": {
                "method": "PUT",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{adminToken}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Updated Node Name\",\n  \"intro\": \"Updated intro\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/admin/nodes/{{nodeId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "admin", "nodes", "{{nodeId}}"]
                },
                "description": "Updates a node by ID. You may also update stream_id or parent_id to re-parent a node."
              },
              "response": []
            },
            {
              "name": "Delete Node",
              "request": {
                "method": "DELETE",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{adminToken}}" }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/admin/nodes/{{nodeId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "admin", "nodes", "{{nodeId}}"]
                },
                "description": "Deletes a node and all its descendants (cascade)."
              },
              "response": []
            },
            {
              "name": "Get Node Assignments",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{adminToken}}" }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/admin/nodes/{{leafNodeId}}/assignments",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "admin", "nodes", "{{leafNodeId}}", "assignments"]
                },
                "description": "Returns current books, institutes and job sectors assigned to a node."
              },
              "response": []
            },
            {
              "name": "Set Node Assignments (leaf only)",
              "request": {
                "method": "PUT",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{adminToken}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"book_ids\": [1, 2, 3],\n  \"institute_ids\": [1, 2],\n  \"job_sector_ids\": [1, 2, 3]\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/admin/nodes/{{leafNodeId}}/assignments",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "admin", "nodes", "{{leafNodeId}}", "assignments"]
                },
                "description": "Atomically replaces all resource assignments for a node.\nReturns 400 if the node has children (non-leaf). Pass empty arrays to clear all assignments."
              },
              "response": []
            }
          ]
        },

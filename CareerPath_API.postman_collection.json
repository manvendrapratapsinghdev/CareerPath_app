                },
                "description": "Returns all institutes ordered by name."
              },
              "response": []
            },
            {
              "name": "List All Job Sectors",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/job_sectors",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "job_sectors"]
                },
                "description": "Returns all job sectors ordered by name."
              },
              "response": []
            }
          ]
        }
      ]

                "url": {
                  "raw": "{{baseUrl}}/api/books",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "books"]
                },
                "description": "Returns all books ordered by title."
              },
              "response": []
            },
            {
              "name": "List All Institutes",
              "request": {
                "method": "GET",
